# Copy to .env.local and fill in. Never commit .env.local.

# --- Admin dashboard (/ak-admin) ------------------------------------------
# Password to sign in. Defaults to "ak-admin" if unset — CHANGE for production.
ADMIN_PASSWORD=change-this-password
# Secret used to sign the admin session cookie (any long random string).
ADMIN_SESSION_SECRET=change-this-to-a-long-random-string

# --- Persistence on Vercel (GitHub-backed) --------------------------------
# REQUIRED on Vercel (read-only disk). When set, admin Save + image upload
# commit to the repo, which triggers a redeploy. Leave unset locally to write
# to disk instead (instant, no commit).
# Fine-grained PAT with "Contents: read & write" on this repo:
GITHUB_TOKEN=
GITHUB_REPO=akhiloliyil/akhil-portfolio
GITHUB_BRANCH=main
